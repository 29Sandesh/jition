{
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://jition.onrender.com/api/:path*" },
    { "source": "/graphql", "destination": "https://jition.onrender.com/graphql" },
    { "source": "/socket.io/:path*", "destination": "https://jition.onrender.com/socket.io/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
