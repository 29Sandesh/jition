                      </div>
                    </div>

                    <div>
                      <h3 className="text-title-lg font-bold text-on-surface border-b border-outline-variant pb-4 mb-6">Company Information</h3>
                    
                    <div className="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
